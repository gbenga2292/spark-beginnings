# Copy this file to .env and fill in your real values
# NEVER commit .env to git — it is already in .gitignore

# --- Supabase (required) ---
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Media Server (required for photo/video uploads in Site Diary) ---
# Point this to your PHP media server
VITE_MEDIA_SERVER_URL=https://dewaterconstruct.com/dcel-app

# --- Build mode ---
# Set to "true" to enable limited web mode (session-based auth, no local persistence)
VITE_WEB_VERSION=false
